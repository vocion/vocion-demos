# Support-reply demo env. Copy to .env.local and fill in.
# Sourced by scripts/dev.sh before starting vocion-core.

# Demo-specific overrides
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# CONTEXT_PATH is set by scripts/dev.sh — don't override here.

# ------------------------------------------------------------------------------
# Clerk Authentication (required)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ------------------------------------------------------------------------------
# Database — PGlite (default, no setup needed). For Postgres, set DATABASE_URL.
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/vocion-support-demo

# ------------------------------------------------------------------------------
# LLM provider keys
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OPENAI_API_KEY=sk-your_key_here

# ------------------------------------------------------------------------------
# App settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_LOGGING_LEVEL=debug
NEXT_TELEMETRY_DISABLED=1
BILLING_PLAN_ENV=dev

# Disable Sentry locally
NEXT_PUBLIC_SENTRY_DISABLED=true
