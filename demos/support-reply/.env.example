# Support-reply demo env. Copy to .env.local and fill in.
# Sourced by scripts/dev.sh before starting the pinned vocion-core.

# Demo-specific overrides
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# CONTEXT_PATH is set by scripts/dev.sh — don't override here.

# ------------------------------------------------------------------------------
# Authentication (vocion-v0.3+ uses NextAuth, not Clerk)
# ------------------------------------------------------------------------------
# AUTH_SECRET — required. The umbrella bootstrap.sh generates one and writes
# it to this .env.local automatically. If you're setting up by hand,
# generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_a_real_secret

# ------------------------------------------------------------------------------
# Database — points at the umbrella docker-compose Postgres (vocion_demo DB).
# The umbrella's bootstrap.sh + docker compose up -d sets this up; override
# below only if running against a different Postgres instance.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vocion_demo

# ------------------------------------------------------------------------------
# Demo credentials banner — autofilled on /sign-in. The seed:demo CLI creates
# a user with these creds; the dashboard's sign-in page reads them via these
# env vars and offers an autofill button so first-time visitors don't have
# to type anything.
# ------------------------------------------------------------------------------
VOCION_DEMO_HINT_EMAIL=demo@example.com
VOCION_DEMO_HINT_PASSWORD=demo123

# ------------------------------------------------------------------------------
# LLM provider keys
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OPENAI_API_KEY=sk-your_key_here

# ------------------------------------------------------------------------------
# App settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_LOGGING_LEVEL=debug
NEXT_TELEMETRY_DISABLED=1
BILLING_PLAN_ENV=dev

# Disable Sentry locally
NEXT_PUBLIC_SENTRY_DISABLED=true
